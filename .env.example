# ─────────────────────────────────────────────────────────────
#  Plantilla de variables de entorno.
#  Copiá este archivo a `.env` y completá los valores reales.
#  El archivo `.env` está en .gitignore y NUNCA debe subirse.
# ─────────────────────────────────────────────────────────────

# ── WooCommerce ──────────────────────────────────────────────
WC_BASE_URL=https://fadua.ar/pruebas
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Estado de los productos a sincronizar ("visibles" en la web = publish)
WC_PRODUCT_STATUS=publish
WC_TIMEOUT_MS=15000
WC_MAX_RETRIES=3

# ── Google Sheets ────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Productos

# ── Email (SMTP / Gmail App Password) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=tejada.ca23@gmail.com
# Enviar un mail de alerta si una corrida falla
MAIL_ON_ERROR=true

# ── Runtime ──────────────────────────────────────────────────
# En modo dry-run se calcula el diff pero NO se escribe ni se envían mails
DRY_RUN=false
LOG_LEVEL=info
